<Window x:Class="MediaDateRenamer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Media Date Renamer"
        Height="400"
        Width="720"
        MinWidth="720"
        MinHeight="400"
		Background="#111"
        Foreground="White"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        DragOver="Window_DragOver"
        Drop="Window_Drop">
		
<Window.Resources>

    <!-- Default text -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <!-- Buttons -->
    <Style TargetType="Button">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="#2b2b2b"/>
        <Setter Property="BorderBrush" Value="#444"/>
        <Setter Property="Padding" Value="6"/>
    </Style>

    <!-- DataGrid -->
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="#1a1a1a"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="RowBackground" Value="#1a1a1a"/>
        <Setter Property="AlternatingRowBackground" Value="#222"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="#333"/>
        <Setter Property="VerticalGridLinesBrush" Value="#333"/>
    </Style>

    <!-- DataGrid headers -->
    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="#2b2b2b"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#444"/>
    </Style>

    <!-- Progress bar -->
    <Style TargetType="ProgressBar">
        <Setter Property="Foreground" Value="#3fa9ff"/>
        <Setter Property="Background" Value="#333"/>
    </Style>

    <!-- Status bar -->
    <Style TargetType="StatusBar">
        <Setter Property="Background" Value="#1a1a1a"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>

</Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="12"
                CornerRadius="8"
                Background="#1e1e1e"
				BorderBrush="#333"
                BorderThickness="1">
            <StackPanel>
                <TextBlock FontSize="22"
                           FontWeight="SemiBold"
                           Text="Media Date Renamer" />
                <TextBlock Margin="0,6,0,0"
                           TextWrapping="Wrap"
                           Text="Drag and drop pictures, videos, or folders anywhere onto this window. Folders are scanned recursively. Click Preview to calculate timestamps and proposed names, then click Rename to apply them." />
            </StackPanel>
        </Border>

        <DockPanel Grid.Row="1"
                   Margin="0,12,0,12"
                   LastChildFill="False">
            <WrapPanel DockPanel.Dock="Left"
                       Orientation="Horizontal">
                <Button Name="AddFilesButton"
                        Width="100"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="AddFilesButton_Click">Add Files</Button>

                <Button Name="AddFolderButton"
                        Width="110"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="AddFolderButton_Click">Add Folder</Button>

                <Button Name="RemoveSelectedButton"
                        Width="130"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="RemoveSelectedButton_Click">Remove Selected</Button>

                <Button Name="ClearButton"
                        Width="90"
                        Height="34"
                        Margin="0,0,16,0"
                        Click="ClearButton_Click">Clear</Button>

                <Button Name="PreviewButton"
                        Width="100"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="PreviewButton_Click">Preview</Button>

                <Button Name="RenameButton"
                        Width="100"
                        Height="34"
                        Click="RenameButton_Click">Rename</Button>
            </WrapPanel>
        </DockPanel>

        <DataGrid Grid.Row="2"
                  Name="FilesGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="False"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowHeaderWidth="0">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Binding="{Binding Selected, Mode=TwoWay}"
                                        Width="40" />
                <DataGridTextColumn Header="Original Path"
                                    Binding="{Binding OriginalPath}"
                                    Width="4*"
                                    IsReadOnly="True" />
                <DataGridTextColumn Header="Detected Date"
                                    Binding="{Binding DetectedDateText}"
                                    Width="1.5*"
                                    IsReadOnly="True" />
                <DataGridTextColumn Header="Source"
                                    Binding="{Binding SourceUsed}"
                                    Width="1.5*"
                                    IsReadOnly="True" />
                <DataGridTextColumn Header="New File Name"
                                    Binding="{Binding NewFileName}"
                                    Width="2*"
                                    IsReadOnly="True" />
                <DataGridTextColumn Header="Status"
                                    Binding="{Binding Status}"
                                    Width="1.2*"
                                    IsReadOnly="True" />
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="3"
              Margin="0,12,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ProgressBar Grid.Row="0"
                         Name="WorkProgressBar"
                         Height="18"
                         Minimum="0"
                         Maximum="100"
                         Value="0" />

            <StatusBar Grid.Row="1"
                       Margin="0,6,0,0">
                <StatusBarItem>
                    <TextBlock Name="StatusText"
                               Text="Ready" />
                </StatusBarItem>
            </StatusBar>
        </Grid>
    </Grid>
</Window>

